# ===========================================
# img2color-go 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并根据实际情况修改配置

# -------------------------------------------
# 服务器配置
# -------------------------------------------

# 服务监听端口（本地运行时使用）
PORT=3000

# -------------------------------------------
# 安全配置
# -------------------------------------------

# 允许的跨域来源（多个用逗号分隔，* 表示允许所有）
ALLOWED_ORIGINS=*

# 允许的Referer来源（多个用逗号分隔，支持通配符*）
# 示例：example.com,*.example.com
ALLOWED_REFERERS=

# 速率限制：每个IP在时间窗口内允许的最大请求数
RATE_LIMIT=100

# 速率限制：时间窗口大小（秒）
RATE_WINDOW=60

# -------------------------------------------
# Redis缓存配置（可选）
# -------------------------------------------

# 是否启用Redis缓存
USE_REDIS_CACHE=false

# Redis服务器地址
REDIS_ADDRESS=localhost:6379

# Redis密码（如果没有设置密码则留空）
REDIS_PASSWORD=

# Redis数据库编号
REDIS_DB=0

# -------------------------------------------
# MongoDB配置（可选）
# -------------------------------------------

# 是否启用MongoDB持久化
USE_MONGODB=false

# MongoDB连接URI
# 示例：mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017

# MongoDB数据库名称
MONGO_DB=img2color

# MongoDB集合名称
MONGO_COLLECTION=colors

# -------------------------------------------
# 图片处理配置
# -------------------------------------------

# 最大图片大小（字节），默认10MB
MAX_IMAGE_SIZE=10485760

# 最大颜色数量
MAX_COLORS=5

# 默认质量
DEFAULT_QUALITY=3

# 默认迭代次数
DEFAULT_ITERATIONS=10

# 图片下载超时时间（秒）
DOWNLOAD_TIMEOUT=10
