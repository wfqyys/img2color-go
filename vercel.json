{
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/img2color.go"
    },
    {
      "source": "/health",
      "destination": "/api/health.go"
    }
  ],
  "functions": {
    "api/*.go": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
